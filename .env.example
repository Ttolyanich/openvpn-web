# Port to expose the service on
PORT=5000

# Address to bind the Flask server to
BIND_HOST=0.0.0.0

# Secret key for Flask sessions (generate a secure random one)
SECRET_KEY=default-secret-key-change-me-please

# URL of the Central Auth Server (use host.docker.internal to route to the host system)
CENTRAL_AUTH_URL=http://host.docker.internal:5001

# Node API Token used to secure node-to-auth-server communication (must match the auth server)
NODE_API_TOKEN=default-token-change-me-please

# Custom name of this VPN node for the browser tab title (defaults to system hostname if blank)
NODE_NAME=VPN-Server-1
